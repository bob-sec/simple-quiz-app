# Copy this file to .env and configure

# Admin password for the quiz admin panel
ADMIN_PASSWORD=your_secure_password_here

# Redis connection (usually no change needed)
REDIS_HOST=redis
REDIS_PORT=6379

# TLS (optional - set to 'true' to enable HTTPS in nginx)
# TLS_ENABLED=false
# TLS_DOMAIN=yourdomain.com
